# Application
NODE_ENV=development
PORT=5001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forex_admin
DB_USER=postgres
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/forex_admin

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (set REDIS_ENABLED=false if Redis is not installed; visitor geo resolves inline, cache is off)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Visitor geography: default is public IPs only. Set VISITOR_GEO_RECORD_NON_PUBLIC=true on a dev machine
# if you want localhost/private IPs stored as "Local or private network" in admin analytics.
# VISITOR_GEO_RECORD_NON_PUBLIC=true

# Session
SESSION_SECRET=your_session_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/v1/auth/google/callback

# Payment Gateways
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Cache
CACHE_API_KEY=your_cache_api_key_here

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=./google-credentials.json
GOOGLE_SHEETS_ID=1bNnoOYUdUm-AFMTL0LPRqsuId1KI3eHMAF-Wz275RGg

# Webhook secret for sheet sync routes (retail sentiment, score dashboard, FX Analyzer technical tables, Edge Tools, COT Data & Analysis, etc.).
# Next.js FX Analyzer page also tries POST /api/v1/admin/fx-analyzer-technical/sync-from-sheets with your login cookie first.
# Edge Tools page tries POST /api/v1/admin/edge-tools/sync-from-sheets with the same cookie, then the webhook below.
# COT Data & Analysis tries POST /api/v1/admin/cot-data-analysis/sync-from-sheets, then POST /api/v1/webhooks/cot-data-analysis/sync-from-sheets.
# If you rely on webhooks only, set the same value in the Next.js server env as SCRAPER_WEBHOOK_SECRET.
SCRAPER_WEBHOOK_SECRET=forex-scraper-webhook-secret

# Edge Tools: Google Sheets ranges → dynamic tables `edge_currency_strength_index`, `edge_forex_pair_analysis`, `edge_technical_dashboard`
# EDGE_SENTIMENT_INDEX_SHEET_NAME=Sentiment Index
# EDGE_CURRENCY_STRENGTH_INDEX_RANGE=A2:J10
# EDGE_FOREX_PAIR_ANALYSIS_RANGE=A15:C43
# EDGE_TECHNICAL_DASHBOARD_SHEET_NAME=New Sheet
# EDGE_TECHNICAL_DASHBOARD_RANGE=A1:AK29

# COT Data & Analysis: tab `RECENT COT DATA 4A` → `currency_pair_sentiment`, `cot_sentiment_net_score`, `cot_raw_data`
# COT_DATA_ANALYSIS_SHEET_NAME=RECENT COT DATA 4A
# Currency Pair Sentiment: T–AA, then AB, skip AC–AE, then AF and AG (merged on sync)
# COT_CURRENCY_PAIR_SENTIMENT_RANGES=T1:AA18,AB1:AB18,AF1:AF18,AG1:AG18
# COT_SENTIMENT_NET_SCORE_RANGE=A24:C51
# COT_RAW_DATA_RANGE=A72:W89

# FX Analyzer: optional overrides for technical trends / levels sync (defaults match product sheet layout)
# FX_ANALYZER_TECHNICAL_TRENDS_SHEET_NAME=New Sheet
# FX_ANALYZER_TECHNICAL_TRENDS_RANGE=A32:AE60
# FX_ANALYZER_TECHNICAL_LEVELS_SHEET_NAME=MAIN SCORE BOARD 2A CLIENT& ADMIN
# FX_ANALYZER_TECHNICAL_LEVELS_RANGE=A169:I197
