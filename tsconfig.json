{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "server.ts",
    "create-admin-user.ts",
    "check-currency-pairs.ts",
    "populate-fx-analyzer-cache.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "logs",
    "migrations",
    "test-*.ts",
    "alias-loader.ts",
    "migrate.ts"
  ]
}
